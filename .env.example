# =========================================
# 🔐 Supabase Configuration
# =========================================

# 📌 Project URL
# 來源：Supabase Dashboard → Project Overview → Project URL
# 格式：https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# 📌 Public Anon Key（前端使用）
# 來源：Supabase Dashboard → Project Settings → API Keys
# 區塊：Legacy anon, service_role API keys
# 請使用 anon / public key（以 eyJ 開頭）
# ⚠️ 請勿使用 service_role !（此為後端專用，具有完整權限）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =========================================
# ⚠️ 使用說明
# =========================================
# 1️⃣ 複製檔案：
#    cp .env.example .env.local
#
# 2️⃣ 填入你的 Supabase 專案設定
#
# 3️⃣ .env.local 不應被 commit（已在 .gitignore 中設定）
#
# 4️⃣ NEXT_PUBLIC_ 開頭變數會暴露在前端（僅可放公開資訊）
#
# 5️⃣ 修改後請重新啟動 Next.js：
#    npm run dev